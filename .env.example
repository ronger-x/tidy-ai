# OpenAI-compatible API key
OPENAI_API_KEY=your_key_here
# API base URL (can be replaced with DeepSeek or any OpenAI-compatible endpoint)
OPENAI_BASE_URL=https://api.openai.com/v1
# Model to use (freely switchable)
OPENAI_MODEL=gpt-4o
# SQLite database file path
DATABASE_URL=./data/tidy.db
# nuxt-auth-utils 会话加密密钥（至少32位随机字符串）
NUXT_SESSION_PASSWORD=your-secret-session-password-at-least-32-chars
